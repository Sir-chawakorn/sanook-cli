# BYOK — เสียบ API key ตรงจาก console ของค่ายเท่านั้น
# ห้าม OAuth / subscription token (Claude.ai / ChatGPT plan) — ละเมิด ToS, บัญชีโดนแบนได้
#
# Claude  → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx
# Gemini  → https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza-xxx
# OpenAI (optional) → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx
#
# optional: เปลี่ยน model (default: sonnet) — เช่น opus | haiku | openai:gpt-5 | google:gemini-2.5-pro | ollama:llama3
SANOOK_MODEL=sonnet
